{
  "name": "dugout",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first agent dev workflow harness: Jira ticket → test-first specs → sandboxed execution → fully-linked PRs.",
  "type": "module",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build:app": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:agent": "vitest run --config vitest.agent.config.ts",
    "build:sandbox": "docker build --provenance=false --sbom=false -t dugout-sandbox:local sandbox/",
    "test:e2e": "electron-vite build && playwright test",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "devDependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.1.0",
    "@fontsource/ibm-plex-mono": "^5.1.0",
    "@fontsource/ibm-plex-sans": "^5.1.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^42.3.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.7.0",
    "motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
